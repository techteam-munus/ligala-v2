{
  "name": "@ligala/infra",
  "private": true,
  "version": "0.0.0",
  "type": "commonjs",
  "scripts": {
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy:dev": "cdk deploy --all --context env=dev --require-approval=never",
    "deploy:prod": "cdk deploy --all --context env=prod",
    "destroy:dev": "cdk destroy --all --context env=dev --force",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint . --ignore-pattern cdk.out --ignore-pattern dist",
    "clean": "rm -rf cdk.out .turbo"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.4.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "aws-cdk": "^2.170.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
