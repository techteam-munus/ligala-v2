{
  "name": "@ligala/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/lambda.js",
  "scripts": {
    "dev": "tsx watch src/dev.ts",
    "build": "esbuild src/lambda.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/lambda.js --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\" --external:@aws-sdk/*",
    "start": "node dist/lambda.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.4.0",
    "@ligala/auth": "workspace:*",
    "@ligala/db": "workspace:*",
    "@ligala/shared": "workspace:*",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@sentry/aws-serverless": "^8.45.0",
    "better-auth": "^1.0.0",
    "ioredis": "^5.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^20.16.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
