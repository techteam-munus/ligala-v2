{
  "name": "@ligala/workers",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "esbuild paymongo/handler.ts paypal/handler.ts idmeta/handler.ts email/handler.ts image/handler.ts --bundle --platform=node --target=node20 --format=esm --outdir=dist --external:@aws-sdk/* --external:sharp",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-ses": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@ligala/db": "workspace:*",
    "@ligala/email": "workspace:*",
    "@ligala/shared": "workspace:*",
    "@sentry/aws-serverless": "^8.45.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^20.16.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "optionalDependencies": {
    "sharp": "^0.33.5"
  }
}
