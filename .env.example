# Copy to .env.local in each app that needs it. Never commit real values.

# --- Database ---
DATABASE_URL=postgres://ligala:ligala@localhost:5432/ligala_dev

# --- Auth (Better Auth) ---
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- API location (used by web to call api) ---
API_URL=http://localhost:8787
NEXT_PUBLIC_API_URL=http://localhost:8787

# --- AWS ---
AWS_REGION=ap-southeast-1
S3_UPLOADS_BUCKET=ligala-v2-dev-uploads
SES_FROM_EMAIL=no-reply@ligala.dev

# --- Redis (ElastiCache in prod, local Redis in dev) ---
REDIS_URL=redis://localhost:6379

# --- Payments ---
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# --- KYC ---
IDMETA_BASE_URL=
IDMETA_TOKEN=
IDMETA_TEMPLATE_ID=
IDMETA_WEBHOOK_SECRET=

# --- Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- CD Asia ---
CDASIA_API_URL=
CDASIA_API_KEY=

# --- Observability ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
