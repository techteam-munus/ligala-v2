{
  "name": "ligala-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:generate": "pnpm --filter @ligala/db generate",
    "db:migrate": "pnpm --filter @ligala/db migrate",
    "db:seed": "pnpm --filter @ligala/db seed",
    "db:studio": "pnpm --filter @ligala/db studio",
    "cdk:synth": "pnpm --filter @ligala/infra synth",
    "cdk:diff": "pnpm --filter @ligala/infra diff",
    "cdk:deploy:dev": "pnpm --filter @ligala/infra deploy:dev",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:load": "echo 'See tests/load/README.md — install k6 then run k6 run tests/load/<script>.js'"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^20.16.0",
    "eslint": "^9.16.0",
    "globals": "^15.13.0",
    "turbo": "^2.1.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.18.0"
  }
}
